# ── Database ──────────────────────────────────────────────
# Default: SQLite (zero setup, local dev)
# DATABASE_URL=sqlite+aiosqlite:///./doclens.db
#
# For Postgres (start with: docker compose up -d):
# DATABASE_URL=postgresql+asyncpg://doclens:doclens@localhost:5432/doclens

# ── Extraction ────────────────────────────────────────────
MODEL_NAME=Qwen/Qwen2.5-VL-3B-Instruct
MAX_PIXELS=1638400
AUTO_APPROVE_THRESHOLD=0.85

# ── File storage ──────────────────────────────────────────
UPLOAD_DIR=./uploads
